// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  name      String
  password  String
  role      UserRole @default(CANDIDATE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  hostedSessions   InterviewSession[] @relation("Interviewer")
  attendedSessions InterviewSession[] @relation("Candidate")
  evaluations      AIEvaluation[]
}

model AIEvaluation {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  role         String
  level        String
  topic        String
  score        Float
  grade        String
  strengths    String[]
  improvements String[]
  idealAnswer  String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, topic])
}

model InterviewSession {
  id          Int           @id @default(autoincrement())
  title       String
  role        String
  level       String
  status      SessionStatus @default(SCHEDULED)
  scheduledAt DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  interviewerId Int
  candidateId   Int
  interviewer   User @relation("Interviewer", fields: [interviewerId], references: [id])
  candidate     User @relation("Candidate", fields: [candidateId], references: [id])

  @@index([interviewerId, scheduledAt])
  @@index([candidateId])
  @@index([status])
}

enum UserRole {
  INTERVIEWER
  CANDIDATE
  ADMIN
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  difficulty  Difficulty
  description String
  examples    Json
  constraints String[]
  testCases   Json
  starterCode Json
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
